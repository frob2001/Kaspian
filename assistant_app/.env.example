APP_ENV=dev
FULLSCREEN=true
ALLOW_ESC_EXIT=true
LANGUAGE=es
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=gemma3:1b
OLLAMA_TIMEOUT=120
DB_PATH=data/app.db
WHISPER_MODEL=small
TTS_ENABLED=true
VOICE_ALWAYS_ON=true
ACTIVATION_NAME=Kaspian
CAMERA_ENABLED=true
FACE_RECOGNITION_ENABLED=true
SPOTIFY_CONTROL_ENABLED=true
SAVE_UNKNOWN_FACES=true
CAMERA_INDEX=0
CAMERA_WIDTH=960
CAMERA_HEIGHT=540
CAMERA_FPS=20
LOG_LEVEL=INFO
SHOW_CAMERA=true
MANUAL_MODE_ENABLED=true
ALLOW_BACKGROUND_MEMORY=false
MAX_RECENT_MESSAGES=12
